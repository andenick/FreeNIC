# FreeNIC environment configuration — copy to .env and edit.
# .env is gitignored; never commit real values.

# --- Paths (only needed to RE-RUN the ingestion pipeline) ---
# Where externally-sourced inputs not bundled under Inputs/ are read from.
DATA_ROOT=./data
# Where derived feature panels (*.parquet) are written.
OUTPUT_ROOT=./outputs

# --- API keys (optional) ---
# Querying the published outputs needs NO keys.
# All current ingestion downloads use keyless public endpoints (FRED CSV,
# FDIC BankFind, FFIEC CDR, Chicago Fed). A free FRED API key is only needed if
# you switch to the rate-limited FRED API endpoints; leave blank otherwise.
# Get one at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
